# Copy this file to .env for local development.
# `docker compose -f docker-compose.yml -f docker-compose.dev.yml`
# reads .env automatically. Never commit your real .env.

# --- Build-time arguments (forwarded to the Dockerfile) --------------
# PHP version for the php:apache base image.
# phpBB 3.3.x supports PHP 7.2 through 8.4.
PHP_VERSION=8.3

# phpBB release version. The Dockerfile builds the tarball URL from
# this — don't override the URL unless you point at a private mirror.
PHPBB_VERSION=3.3.17

# Image tag baked into the built image (helps distinguish prod vs
# dev images when you push to a registry later).
PHPBB_IMAGE_TAG=3.3.17

# --- Public hostname --------------------------------------------------
# Dev:    forum.local (must match /etc/hosts + Caddyfile + mkcert name)
# Prod:   forum.example.com (set this in the Dokploy UI)
PHPBB_WEB_HOST=forum.local

# --- TLS / reverse proxy ---------------------------------------------
# Both dev (Caddy) and prod (Traefik) terminate TLS in front of the
# container, so the same settings work in both environments.
PHPBB_WEB_PROTOCOL=https
PHPBB_BEHIND_PROXY=1

# --- Database ---------------------------------------------------------
# Dev:    the in-stack MariaDB service (host "db" inside compose).
# Prod:   the Dokploy-managed database (host set in the Dokploy UI).
PHPBB_DB_TYPE=mysqli
PHPBB_DB_HOST=db
PHPBB_DB_PORT=3306
PHPBB_DB_NAME=phpbb
PHPBB_DB_USER=phpbb
PHPBB_DB_PASSWORD=phpbb
PHPBB_TABLE_PREFIX=phpbb_

# --- Debug ------------------------------------------------------------
# Dev:  1  (verbose output, lenient defaults)
# Prod: 0  (silent, strict)
PHPBB_DEBUG=1
PHPBB_ENVIRONMENT=development

# --- Dev-only ---------------------------------------------------------
# Direct host port to the phpbb container for debugging. Ignored in prod.
PHPBB_HTTP_PORT=8000

# --- Bootstrap (CLI installer) ----------------------------------------
# The first time the phpbb container starts, the entrypoint runs
# `php install/phpbbcli.php install` with these values. They end up
# in the database (admin user, board name) — change them before the
# first boot to install with your values; later changes need a
# `docker exec ... php install/phpbbcli.php update` run.
#
# In dev, weak values are fine. In prod, set a real password (or
# wire these to a secrets manager) BEFORE the first boot.
PHPBB_ADMIN_NAME=admin
PHPBB_ADMIN_PASSWORD=admin123
PHPBB_ADMIN_EMAIL=admin@example.com
PHPBB_BOARD_NAME=wiki-forum-dev
PHPBB_BOARD_DESCRIPTION=phpBB forum for local development
PHPBB_BOARD_LANG=en
PHPBB_COOKIE_SECURE=true

# --- phpBB extensions -------------------------------------------------
# Comma-separated list of vendor/ext names to enable on container
# start. Each one must exist in /var/www/html/ext/ — in dev, code
# under ./extensions/ is copied there by the entrypoint (phase 2.6).
# In prod, the same code is baked into the image by the Dockerfile.
# Example:  PHPBB_EXTENSIONS="comunidad/portal,other/vendor"
# Leave empty to enable extensions manually via the ACP.
PHPBB_EXTENSIONS=
